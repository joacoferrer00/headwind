# Copy this file to .env and fill in the values. .env is gitignored.

# OpenSky Network — REST API (OAuth2 client credentials flow).
# Get these by activating the "API Client Interface" on your OpenSky account page.
# The client_id usually ends in `-api-client`.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# OpenSky Network — Trino interface (SQL access to historical warehouse).
# Uses the website login (email/username + password).
# Only needed if we use Trino instead of (or alongside) the REST API.
OPENSKY_TRINO_USER=
OPENSKY_TRINO_PASS=

# GCP project (already set up, here for reference / scripts)
GCP_PROJECT=headwind-497302
GCS_RAW_BUCKET=headwind-497302-raw
BQ_LOCATION=EU
BQ_RAW_DATASET=headwind_raw
